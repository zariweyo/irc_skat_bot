{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "IRC Bot",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/app/bot.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "IRC Bot (debug)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/app/debug.py",
            "args": ["--nick", "Tester"],
            "console": "integratedTerminal",
            "justMyCode": true,
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}
